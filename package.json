{
  "name": "product-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for product team apps consuming @qijenchen/design-system",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "echo 'Pick an app: cd apps/<name> && npm run dev' && exit 1",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "create-app": "node scripts/create-app.mjs",
    "lint:imports": "node scripts/lint-ds-internal-imports.mjs"
  },
  "dependencies": {
    "@qijenchen/design-system": "beta",
    "@qijenchen/storybook-config": "beta",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "storybook": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
