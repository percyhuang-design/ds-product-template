# ds-product-template fork-and-go onboarding 預設(可選)
#
# Copy to .env(被 .gitignore 忽略)讓 `npm run setup:netlify` 無需互動 prompt:
#
#   cp .env.example .env
#   # edit .env(team emails)
#   npm run setup:netlify
#
# 或全跳過 invite 不設 .env:
#   npm run setup:netlify -- --skip-invite

# Comma-separated team emails to auto-invite(若不設,setup script 互動 prompt)
NETLIFY_TEAM_EMAILS=
